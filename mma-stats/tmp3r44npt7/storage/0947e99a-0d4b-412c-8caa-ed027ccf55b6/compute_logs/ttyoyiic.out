
        CREATE TABLE IF NOT EXISTS mma_stats_bronze.ufc_athletes_records 
        (`Athlete_ID` String, `Opponent_ID` String, `Fight_Date` String, `Last_Round` String, `End_Time` String, `Victory_Method` String, `Fight_Result` String) 
        ENGINE = MergeTree 
        ORDER BY (`Athlete_ID`, `Opponent_ID`, `Fight_Date`)
    
